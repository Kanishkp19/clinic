# Compiled source #
###################
*.com
*.class
*.dll
*.exe
*.o
*.so

# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Logs and databases #
######################
*.log
*.sql
*.sqlite

# OS generated files #
######################
.idea
.vscode
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ZiON ignored files #
node_modules
temp

# Next.js build output #
########################
# .next is generated by `next dev` / `next build`. It must NOT be committed:
# committing it ships a stale dev-time snapshot whose asset hashes / BUILD_ID
# no longer match the server's fresh build, breaking the site in production.
.next
out
next-env.d.ts

# Env files #
#############
.env
.env*.local
